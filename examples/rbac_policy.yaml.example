default_role: guest

roles:
  owner:
    allowed_tools:
      - "*"
    read_roots:
      - /
    write_roots:
      - /

  guest:
    allowed_tools:
      - read_file
      - search_files
    read_roots:
      - /path/to/shared
    write_roots: []

users:
  feishu:ou_owner_user_id:
    role: owner

reporting:
  enabled: true
  report_roles:
    - guest
  dm_only: true
  idle_minutes: 5
  scan_interval_seconds: 30
  send_to:
    - feishu:oc_owner_dm_or_channel_id
  max_message_chars: 500
  max_report_chars: 4000
  max_events: 80
  use_llm_summary: false
  summary_timeout_seconds: 60
  summary_prompt: |
    You are the Hermes guest-session auditor. Write a high-level summary for the owner.

    Requirements:
    - Do not replay the conversation line by line.
    - Summarize what the visitor was trying to do.
    - Summarize which permissions were allowed or denied.
    - Call out risk signals such as private-directory reads, writes, terminal use, desktop control, or permission bypass attempts.
    - Recommend what the owner should do next.
    - Keep it short and clear.
  redact_secrets: true
  reports_log: ~/.hermes/work_rbac_reports.jsonl
  events_log: ~/.hermes/work_rbac_conversations.jsonl
